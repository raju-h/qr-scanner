# .env.example — copy to .env.local (dev) or .env.production (prod)

# Database connection string
# Dev: local Docker Postgres
# Prod: AWS RDS endpoint with connection pooling
DATABASE_URL="postgresql://qrscanner:localdev@localhost:5432/qrscanner?schema=public"

# Node environment
NODE_ENV="development"

# Public app URL (used for metadata, OG tags)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Domain for Traefik routing (production only)
APP_DOMAIN="qrscanner.yourdomain.com"

# Email for Let's Encrypt certificate notifications (production only)
ACME_EMAIL="your@email.com"
